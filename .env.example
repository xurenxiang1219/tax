# Database
DATABASE_URL="file:./dev.db"

# File Upload
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=./uploads/invoices

# OCR
OCR_TIMEOUT=30000  # 30 seconds in milliseconds
OCR_PROVIDER=tesseract  # tesseract or azure

# Azure OCR (optional)
AZURE_VISION_ENDPOINT=https://azureocrtest1219.cognitiveservices.azure.com/
AZURE_VISION_KEY=t
